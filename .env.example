# Copy this file to .env (for local dev) or set these vars in your hosting dashboard.
#
# ─── Backend API URL ──────────────────────────────────────────────────────────
# Point this to wherever your Node/Express backend is deployed.
# Examples:
#   Local dev  → http://localhost:5000/api
#   Render     → https://servicehub-api.onrender.com/api
#   Railway    → https://servicehub-api.up.railway.app/api
#   Custom     → https://api.yourdomain.com/api
VITE_API_URL=https://your-backend-url.com/api

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# Same Client ID used in the backend (from Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
